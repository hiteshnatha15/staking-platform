# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Solana - Networking Token Staking
VITE_TOKEN_MINT=YourSPLTokenMintAddress
VITE_STAKING_VAULT=YourVaultWalletPublicKey
VITE_TOKEN_SYMBOL=NET
VITE_TOKEN_DECIMALS=9
# Use Ankr if mainnet-beta has rate limits: https://rpc.ankr.com/solana
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Optional: Birdeye API key for live token price (DexScreener used first if no key)
# Get key at docs.birdeye.so - needed if token has no pairs on DexScreener
# VITE_BIRDEYE_API_KEY=your-birdeye-api-key
